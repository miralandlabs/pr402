# pr402 Environment Variables Template

# Required: Solana RPC endpoint
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Required: Solana chain ID (CAIP-2 format)
# Mainnet: solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp
# Devnet: solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1wcaWoxPkrZBG
SOLANA_CHAIN_ID=solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp

# Required: Fee payer private key (base58 encoded, 64 bytes)
FEE_PAYER_PRIVATE_KEY=your_base58_private_key_here

# Optional: Solana WebSocket pubsub URL
# SOLANA_PUBSUB_URL=wss://api.mainnet-beta.solana.com

# Optional: Maximum compute unit limit (default: 400000)
# MAX_COMPUTE_UNIT_LIMIT=400000

# Optional: Maximum compute unit price (default: 1000000)
# MAX_COMPUTE_UNIT_PRICE=1000000

# Optional: Logging level (default: info)
# RUST_LOG=info

# Optional: UniversalSettle configuration (for fee-charging facilitator)
# If set, facilitator will use UniversalSettle program for settlement with fee deduction
# UNIVERSALSETTLE_PROGRAM_ID=univceHgmTuGjoKtFh2MqJsUyu7tEny2yy4tnaD1QP5

