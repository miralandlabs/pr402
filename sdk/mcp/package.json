{
  "name": "@pr402/mcp-server",
  "version": "0.1.2",
  "description": "MCP server for pr402 on Solana — buyer auto-pay and seller facilitator tools via @pr402/client.",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "type": "commonjs",
  "bin": {
    "pr402-mcp": "dist/server.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"require('fs').chmodSync('dist/server.js', 0o755)\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@pr402/client": "^0.3.0",
    "@solana/web3.js": "^1.87.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5.0.0"
  },
  "engines": {
