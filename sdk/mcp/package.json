  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "x402",
    "solana",
    "pr402",
    "usdc",
    "ai-agents",
    "cursor",
    "facilitator"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/miralandlabs/pr402/tree/main/sdk/mcp#readme",
  "bugs": {
    "url": "https://github.com/miralandlabs/pr402/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miralandlabs/pr402.git",
    "directory": "sdk/mcp"
  },
  "publishConfig": {
    "access": "public"
  }
