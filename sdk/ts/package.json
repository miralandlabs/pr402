{
  "name": "@pr402/client",
  "version": "0.3.0",
  "description": "Lightweight NPM library + CLI for autonomous agents paying HTTP 402 APIs settled on Solana via pr402.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "commonjs",
  "bin": {
    "pr402-buy": "dist/cli.js"
  },
  "files": [
    "dist",
