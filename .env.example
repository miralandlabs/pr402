# pr402 facilitator — copy to .env for local runs (never commit real secrets).

# --- Required (Solana + fee payer) ---
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CHAIN_ID=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1wpxWaq2mpjG

# Required: Fee payer private key (base58 encoded, 64 bytes)
FEE_PAYER_PRIVATE_KEY=

# --- Optional Solana ---
# WebSocket pubsub URL: not wired in pr402 yet (only SOLANA_RPC_URL is used for RpcClient). Safe to leave empty on Vercel or anywhere.
SOLANA_PUBSUB_URL=
MAX_COMPUTE_UNIT_LIMIT=400000
MAX_COMPUTE_UNIT_PRICE=1000000

# --- Settlement programs (scheme-specific; set the one(s) you actually use) ---
# `v2:solana:exact` (UniversalSettle vault / fees / sweep): set UNIVERSALSETTLE_PROGRAM_ID.
# `v2:solana:sla-escrow`: set ESCROW_PROGRAM_ID (this scheme is registered only when set).
# You may set both. For typical RP flows, at least one must match paymentRequirements.scheme.
# The process can start with neither (limited / unsupported paths for real traffic).
UNIVERSALSETTLE_PROGRAM_ID=
ESCROW_PROGRAM_ID=

# --- Optional PostgreSQL (same DATABASE_URL / pool behavior as signer-payer-serverless-copy) ---
DATABASE_URL=

# --- Signed onboard (challenge + POST /api/v1/facilitator/onboard) ---
# Prefer storing these in `parameters` table to save Vercel env bytes (see migrations/init.sql).
# Resolution: non-empty `parameters.param_value` wins, else these env vars (see `parameters::resolve_string`).
PR402_ONBOARD_HMAC_SECRET=
PR402_ONBOARD_CHALLENGE_TTL_SEC=600

# --- In-memory parameters cache (env only; not a `parameters` table row) ---
# Seconds between Postgres re-fetches per serverless instance; see `parameters::parameters_cache_ttl`.
PR402_PARAMETERS_CACHE_TTL_SEC=60

# --- UniversalSettle sweep preflight (RPC read only; skips sweep tx if vault below floor) ---
# Prefer `parameters` rows from migrations/init.sql seed section.
# 0.03 SOL = 30_000_000 lamports; typical stablecoin 6 decimals: $3 = 3_000_000 raw (default for unlisted mints).
PR402_SWEEP_MIN_SPENDABLE_LAMPORTS=30000000
PR402_SWEEP_MIN_SPL_RAW_DEFAULT=3000000
PR402_SWEEP_MIN_SPL_RAW_BY_MINT={"EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v":"3000000"}

# --- Logging ---
RUST_LOG=info
