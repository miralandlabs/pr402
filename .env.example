# pr402 facilitator — copy to .env for local runs (never commit real secrets).

# --- Required (Solana + fee payer) ---
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_CHAIN_ID=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1wpxWaq2mpjG

# Required: Fee payer private key (base58 encoded, 64 bytes)
FEE_PAYER_PRIVATE_KEY=

# --- Optional Solana ---
# WebSocket pubsub URL: not wired in pr402 yet (only SOLANA_RPC_URL is used for RpcClient). Safe to leave empty on Vercel or anywhere.
SOLANA_PUBSUB_URL=
# DEPRECATED
# MAX_COMPUTE_UNIT_LIMIT=400000
# MAX_COMPUTE_UNIT_PRICE=1000000

# --- Settlement programs (scheme-specific; set the one(s) you actually use) ---
# `v2:solana:exact` (UniversalSettle vault / fees / sweep): set UNIVERSALSETTLE_PROGRAM_ID.
# `v2:solana:sla-escrow`: set ESCROW_PROGRAM_ID (this scheme is registered only when set).
# You may set both. For typical RP flows, at least one must match paymentRequirements.scheme.
# The process can start with neither (limited / unsupported paths for real traffic).
UNIVERSALSETTLE_PROGRAM_ID=
ESCROW_PROGRAM_ID=

# --- Optional PostgreSQL (same DATABASE_URL / pool behavior as signer-payer-serverless-copy) ---
DATABASE_URL=

# --- Signed onboard (challenge + POST /api/v1/facilitator/onboard) ---
# Prefer storing these in `parameters` table to save Vercel env bytes (see migrations/init.sql).
# Resolution: non-empty `parameters.param_value` wins, else these env vars (see `parameters::resolve_string`).
PR402_ONBOARD_HMAC_SECRET=
PR402_ONBOARD_CHALLENGE_TTL_SEC=600

# --- In-memory parameters cache (env only; not a `parameters` table row) ---
# Seconds between Postgres re-fetches per serverless instance; see `parameters::parameters_cache_ttl`.
PR402_PARAMETERS_CACHE_TTL_SEC=60

# Clients may request facilitator-paid fees when allowed(true/false, 1/0, yes/no)
PR402_SLA_ESCROW_ALLOW_FACILITATOR_FEE_SPONSORSHIP=false

# Default oracle tip basis points advertised on /capabilities and applied when pr402
# opens an escrow on behalf of a buyer. The sla-escrow Bank has no facilitator-wide
# default for this; it is a per-escrow field on-chain. Capped at 500 by the program
# (MAX_ORACLE_FEE_BPS). 50 = 0.50%. Leave unset to use the built-in default (50).
# PR402_SLA_ESCROW_DEFAULT_ORACLE_FEE_BPS=50

# --- SLA-Escrow oracle profiles published on GET /capabilities (optional; only read when ESCROW_PROGRAM_ID is set) ---
#
# All keys below follow pr402's parameters-first convention: each is read with
# `parameters::resolve_string_sync(KEY, KEY)` so the **DB `parameters` row wins**
# (preferred for Vercel deployments to avoid the env-size limit), else the matching
# env var of the same name. Seed the table via migrations/init.sql or insert rows
# at runtime; nothing below has to live in the env if you'd rather keep it in DB.
#
# Two configuration modes (mutually exclusive — JSON wins when set):
#
# 1. Full JSON override (high-flexibility): full array verbatim. Fields per entry:
#    profileId, normativeSpecUrl, repositoryPath, defaultOperatorPubkey,
#    registryUrl, evidenceRegistryNote.
# PR402_SLA_ESCROW_ORACLE_PROFILES_JSON=[{"profileId":"x402/oracles/api-quality/v1","defaultOperatorPubkey":"OracleAuthorityPubkey..."}]
#
# 2. Ergonomic per-profile keys (one set per advertised profile). Each profile is
#    only emitted on /capabilities when its DEFAULT_PUBKEY is set. NORMATIVE_SPEC_URL,
#    REGISTRY_URL, EVIDENCE_REGISTRY_NOTE are optional; NORMATIVE_SPEC_URL has a
#    sensible GitHub default.
#
# api-quality oracle (JSON API delivery quality):
# PR402_SLA_ESCROW_API_QUALITY_DEFAULT_PUBKEY=
# PR402_SLA_ESCROW_API_QUALITY_NORMATIVE_SPEC_URL=
# PR402_SLA_ESCROW_API_QUALITY_REGISTRY_URL=
# PR402_SLA_ESCROW_API_QUALITY_EVIDENCE_REGISTRY_NOTE=
#
# onchain-transfer oracle (SPL transfer / swap delivery):
# PR402_SLA_ESCROW_ONCHAIN_TRANSFER_DEFAULT_PUBKEY=
# PR402_SLA_ESCROW_ONCHAIN_TRANSFER_NORMATIVE_SPEC_URL=
# PR402_SLA_ESCROW_ONCHAIN_TRANSFER_REGISTRY_URL=
# PR402_SLA_ESCROW_ONCHAIN_TRANSFER_EVIDENCE_REGISTRY_NOTE=
#
# file-delivery oracle (large-file streaming attestation):
# PR402_SLA_ESCROW_FILE_DELIVERY_DEFAULT_PUBKEY=
# PR402_SLA_ESCROW_FILE_DELIVERY_NORMATIVE_SPEC_URL=
# PR402_SLA_ESCROW_FILE_DELIVERY_REGISTRY_URL=
# PR402_SLA_ESCROW_FILE_DELIVERY_EVIDENCE_REGISTRY_NOTE=

# --- UniversalSettle sweep preflight (RPC read only; skips sweep tx if vault below floor) ---
# Prefer `parameters` rows from migrations/init.sql seed section.
# 0.03 SOL = 30_000_000 lamports; typical stablecoin 6 decimals: $3 = 3_000_000 raw (default for unlisted mints).
PR402_SWEEP_MIN_SPENDABLE_LAMPORTS=30000000
PR402_SWEEP_MIN_SPL_RAW_DEFAULT=3000000
PR402_SWEEP_MIN_SPL_RAW_BY_MINT={"EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v":"3000000"}

# --- Logging ---
# Optional. Unset or empty → pr402 uses `server_log=info` (Vercel often leaves RUST_LOG empty; the
# stock `try_from_default_env` path would otherwise stay ERROR-only and hide audit lines).
# If you set RUST_LOG, pr402 still merges `server_log=info`. Example: RUST_LOG=warn,hyper=warn
RUST_LOG=
