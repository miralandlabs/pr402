{
  "version": 2,
  "redirects": [
    {
      "source": "/openai.json",
      "destination": "/openapi.json",
      "permanent": true
    },
    {
      "source": "/api/v1/facilitator/openapi.json",
      "destination": "/openapi.json",
      "permanent": false
    },
    {
      "source": "/api/v1/facilitator/agent-integration.md",
      "destination": "/agent-integration.md",
      "permanent": false
    },
    {
      "source": "/api/v1/facilitator/onboarding_guide.md",
      "destination": "/onboarding_guide.md",
      "permanent": false
    },
    {
      "source": "/api/v1/facilitator/agent-payTo-semantics.json",
      "destination": "/agent-payTo-semantics.json",
      "permanent": false
    },
    {
      "source": "/api/v1/facilitator/agent-tools.json",
      "destination": "/agent-tools.json",
      "permanent": false
    },
    {
      "source": "/api/v1/facilitator/seller-endpoint-guide.json",
      "destination": "/seller-endpoint-guide.json",
      "permanent": false
    },
    {
      "source": "/api/v1/facilitator/quickstart-buyer.md",
      "destination": "/quickstart-buyer.md",
      "permanent": false
    },
    {
      "source": "/api/v1/facilitator/quickstart-seller.md",
      "destination": "/quickstart-seller.md",
      "permanent": false
    }
  ],
  "builds": [
    {
      "src": "src/bin/facilitator.rs",
      "use": "vercel-rust@4.0.8",
      "config": {
        "env": {
          "CARGO_HOME": "/tmp/cargo",
          "RUSTUP_HOME": "/tmp/rustup"
        }
      }
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/src/bin/facilitator",
      "methods": [
        "GET",
        "HEAD",
        "OPTIONS"
      ]
    },
    {
      "src": "/robots.txt",
      "dest": "/public/robots.txt"
    },
    {
      "src": "/sitemap.xml",
      "dest": "/public/sitemap.xml"
    },
    {
      "src": "/openapi.json",
      "dest": "/public/openapi.json"
    },
    {
      "src": "/wallet.js",
      "dest": "/public/wallet.js"
    },
    {
      "src": "/agent-integration.md",
      "dest": "/public/agent-integration.md"
    },
    {
      "src": "/onboarding_guide.md",
      "dest": "/public/onboarding_guide.md"
    },
    {
      "src": "/agent-payTo-semantics.json",
      "dest": "/public/agent-payTo-semantics.json"
    },
    {
      "src": "/agent-tools.json",
      "dest": "/public/agent-tools.json"
    },
    {
      "src": "/seller-endpoint-guide.json",
      "dest": "/public/seller-endpoint-guide.json"
    },
    {
      "src": "/quickstart-buyer.md",
      "dest": "/public/quickstart-buyer.md"
    },
    {
      "src": "/quickstart-seller.md",
      "dest": "/public/quickstart-seller.md"
    },
    {
      "src": "/seller-quick-start.md",
      "dest": "/public/seller-quick-start.md"
    },
    {
      "src": "/pr402.png",
      "dest": "/public/pr402.png"
    },
    {
      "src": "/favicon.ico",
      "dest": "/public/pr402.png"
    },
    {
      "src": "/apple-touch-icon(-precomposed)?\\.png",
      "dest": "/public/pr402.png"
    },
    {
      "src": "/api/v1/facilitator/verify",
      "dest": "/src/bin/facilitator",
      "methods": [
        "POST",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/settle",
      "dest": "/src/bin/facilitator",
      "methods": [
        "POST",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/payment-required/enrich",
      "dest": "/src/bin/facilitator",
      "methods": [
        "GET",
        "HEAD",
        "POST",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/sellers/provision-tx",
      "dest": "/src/bin/facilitator",
      "methods": [
        "POST",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/sellers/(?<wallet>[^/]+)/preview",
      "dest": "/src/bin/facilitator",
      "methods": [
        "GET",
        "HEAD",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/sellers/(?<wallet>[^/]+)/challenge",
      "dest": "/src/bin/facilitator",
      "methods": [
        "GET",
        "HEAD",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/sellers/(?<wallet>[^/]+)/register",
      "dest": "/src/bin/facilitator",
      "methods": [
        "POST",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/sellers/(?<wallet>[^/]+)/retire",
      "dest": "/src/bin/facilitator",
      "methods": [
        "POST",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/sellers/(?<wallet>[^/]+)/rails/(?<scheme>[^/]+)",
      "dest": "/src/bin/facilitator",
      "methods": [
        "GET",
        "HEAD",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/supported",
      "dest": "/src/bin/facilitator",
      "methods": [
        "GET",
        "HEAD",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/health",
      "dest": "/src/bin/facilitator",
      "methods": [
        "GET",
        "HEAD",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/capabilities",
      "dest": "/src/bin/facilitator",
      "methods": [
        "GET",
        "HEAD",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/providers",
      "dest": "/src/bin/facilitator",
      "methods": [
        "GET",
        "HEAD",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/providers/(?<wallet>[^/]+)",
      "dest": "/src/bin/facilitator",
      "methods": [
        "GET",
        "HEAD",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/seller/payments",
      "dest": "/src/bin/facilitator",
      "methods": [
        "POST",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/vault-snapshot",
      "dest": "/src/bin/facilitator",
      "methods": [
        "GET",
        "HEAD",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/build-exact-payment-tx",
      "dest": "/src/bin/facilitator",
      "methods": [
        "POST",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/build-sla-escrow-payment-tx",
      "dest": "/src/bin/facilitator",
      "methods": [
        "POST",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/build-refund-tx",
      "dest": "/src/bin/facilitator",
      "methods": [
        "POST",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/oracle/build-confirm",
      "dest": "/src/bin/facilitator",
      "methods": [
        "POST",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/sweep",
      "dest": "/src/bin/facilitator",
      "methods": [
        "POST",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/sweep-cron",
      "dest": "/src/bin/facilitator",
      "methods": [
        "GET",
        "HEAD",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/sla-escrow-settle",
      "dest": "/src/bin/facilitator",
      "methods": [
        "POST",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/sla-escrow-settle-cron",
      "dest": "/src/bin/facilitator",
      "methods": [
        "GET",
        "HEAD",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/sla-escrow-close",
      "dest": "/src/bin/facilitator",
      "methods": [
        "POST",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/sla-escrow-close-cron",
      "dest": "/src/bin/facilitator",
      "methods": [
        "GET",
        "HEAD",
        "OPTIONS"
      ]
    },
    {
      "src": "/api/v1/facilitator/build-sla-escrow-settle-tx",
      "dest": "/src/bin/facilitator",
      "methods": [
        "POST",
        "OPTIONS"
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/v1/facilitator/sweep-cron",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/v1/facilitator/sla-escrow-settle-cron",
      "schedule": "*/5 * * * *"
    }
  ]
}
